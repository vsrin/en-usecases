# Never cache the SPA shell — so new deploys pick up new asset hashes immediately.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# Built assets are hash-named — cache them aggressively and immutably.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static HTML (demoboards, legacy usecases) — short cache so edits propagate.
/demoboards/*
  Cache-Control: public, max-age=300, must-revalidate

/usecases/*
  Cache-Control: public, max-age=300, must-revalidate
